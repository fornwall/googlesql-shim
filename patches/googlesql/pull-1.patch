From 8d06b161dfd9fcbc69ab9765713ad817ebc31104 Mon Sep 17 00:00:00 2001
From: Fredrik Fornwall <fredrik@fornwall.net>
Date: Wed, 22 Jul 2026 19:01:26 +0200
Subject: [PATCH] Split the local service's evaluator RPCs into their own
 cc_library

//googlesql/local_service:local_service implements all the local-service
RPCs in one translation unit, so the Prepare/Evaluate/Unprepare RPC
families pull //googlesql/public:evaluator -- and with it the whole
reference implementation, including algebrizer.cc, one of the largest
compile actions on a cold build -- into every consumer, even one that
only parses and analyzes SQL.

Split the target in two:

- local_service_analysis (new): GoogleSqlLocalServiceAnalysisImpl
  implements every RPC except the Prepare/Evaluate/Unprepare families,
  plus the registered descriptor-pool and catalog state those families
  share with the analysis RPCs, with no dependency on the evaluator or
  the reference implementation.

- local_service: GoogleSqlLocalServiceImpl now derives from the
  analysis class and adds the evaluator-backed RPC families. Its API
  and behavior are unchanged, and it remains the target the gRPC
  server, the JNI bindings and the tests build against.

Besides the shared registration state, the one coupling between the
halves is AnalyzerOptions.use_constant_evaluator, which needs a
PreparedExpressionConstantEvaluator (and hence the evaluator) inside
the Analyze RPC. That is now a virtual hook: the analysis-only class
rejects the option with kUnimplemented, and GoogleSqlLocalServiceImpl
overrides the hook with the evaluator-backed implementation, preserving
existing behavior for the full service.

Front-end-only consumers can now depend on
//googlesql/local_service:local_service_analysis and skip compiling the
evaluator entirely.

Signed-off-by: Fredrik Fornwall <fredrik@fornwall.net>
---
 googlesql/local_service/BUILD                 |  55 +-
 googlesql/local_service/local_service.cc      | 817 +-----------------
 googlesql/local_service/local_service.h       | 125 +--
 .../local_service/local_service_analysis.cc   | 803 +++++++++++++++++
 .../local_service/local_service_analysis.h    | 306 +++++++
 5 files changed, 1178 insertions(+), 928 deletions(-)
 create mode 100644 googlesql/local_service/local_service_analysis.cc
 create mode 100644 googlesql/local_service/local_service_analysis.h

diff --git a/googlesql/local_service/BUILD b/googlesql/local_service/BUILD
index 50f2aa5b6..6b7d42c7b 100644
--- a/googlesql/local_service/BUILD
+++ b/googlesql/local_service/BUILD
@@ -26,11 +26,16 @@ load("@rules_cc//cc:cc_test.bzl", "cc_test")
 # GoogleSQL Server
 package(default_visibility = ["//googlesql/base:googlesql_implementation"])
 
+# The analysis-only half of the local service: every RPC except the
+# Prepare/Evaluate/Unprepare families. This target deliberately does not
+# depend on //googlesql/public:evaluator or the reference implementation, so
+# consumers that only parse and analyze SQL can depend on it without
+# compiling the evaluator.
 cc_library(
-    name = "local_service",
-    srcs = ["local_service.cc"],
+    name = "local_service_analysis",
+    srcs = ["local_service_analysis.cc"],
     hdrs = [
-        "local_service.h",
+        "local_service_analysis.h",
         "state.h",
     ],
     deps = [
@@ -50,8 +55,6 @@ cc_library(
         "//googlesql/public:builtin_function_options",
         "//googlesql/public:catalog",
         "//googlesql/public:constant_evaluator",
-        "//googlesql/public:evaluator",
-        "//googlesql/public:evaluator_table_iterator",
         "//googlesql/public:formatter_options",
         "//googlesql/public:function",
         "//googlesql/public:id_string",
@@ -59,7 +62,6 @@ cc_library(
         "//googlesql/public:lenient_formatter",
         "//googlesql/public:parse_resume_location",
         "//googlesql/public:parse_resume_location_cc_proto",
-        "//googlesql/public:prepared_expression_constant_evaluator",
         "//googlesql/public:simple_catalog",
         "//googlesql/public:simple_catalog_util",
         "//googlesql/public:simple_table_cc_proto",
@@ -86,6 +88,47 @@ cc_library(
     ],
 )
 
+# The full local service: the analysis RPCs plus the
+# Prepare/Evaluate/Unprepare RPC families, which pull in the evaluator and
+# with it the reference implementation.
+cc_library(
+    name = "local_service",
+    srcs = ["local_service.cc"],
+    hdrs = ["local_service.h"],
+    deps = [
+        ":local_service_analysis",
+        ":local_service_cc_proto",
+        "//googlesql/base:map_util",
+        "//googlesql/base:ret_check",
+        "//googlesql/base:status",
+        "//googlesql/common:errors",
+        "//googlesql/proto:options_cc_proto",
+        "//googlesql/public:analyzer",
+        "//googlesql/public:catalog",
+        "//googlesql/public:constant_evaluator",
+        "//googlesql/public:evaluator",
+        "//googlesql/public:evaluator_table_iterator",
+        "//googlesql/public:parse_resume_location",
+        "//googlesql/public:parse_resume_location_cc_proto",
+        "//googlesql/public:prepared_expression_constant_evaluator",
+        "//googlesql/public:simple_catalog",
+        "//googlesql/public:simple_table_cc_proto",
+        "//googlesql/public:type",
+        "//googlesql/public:type_cc_proto",
+        "//googlesql/public:value",
+        "//googlesql/public:value_cc_proto",
+        "@com_google_absl//absl/cleanup",
+        "@com_google_absl//absl/container:flat_hash_set",
+        "@com_google_absl//absl/functional:bind_front",
+        "@com_google_absl//absl/memory",
+        "@com_google_absl//absl/status",
+        "@com_google_absl//absl/status:statusor",
+        "@com_google_absl//absl/strings",
+        "@com_google_absl//absl/types:optional",
+        "@com_google_protobuf//:protobuf",
+    ],
+)
+
 cc_test(
     name = "local_service_test",
     srcs = ["local_service_test.cc"],
