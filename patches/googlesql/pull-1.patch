-    return MakeSqlError() << "Unknown catalog ID: " << id;
-  }
-
-  absl::Status status;
-  for (int64_t pool_id : state->owned_descriptor_pool_ids()) {
-    if (!registered_descriptor_pools_->Delete(pool_id)) {
-      status = MakeSqlError() << "Unknown descriptor pool ID: " << pool_id;
-    }
