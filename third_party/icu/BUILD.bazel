# Support files for the native ICU build; the BUILD file applied to the
# @icu repo itself is icu.BUILD (see MODULE.bazel).

load("@rules_python//python:defs.bzl", "py_binary")

py_binary(
    name = "dat_to_c",
    srcs = ["dat_to_c.py"],
    visibility = ["//visibility:public"],
)

# Removes items GoogleSQL has no runtime path to (charset converters, locale
# display-name trees, ...) from the ICU data before it is embedded, ~16 MB
# off the shipped data. See filter_dat.py and icu_data_remove.txt.
py_binary(
    name = "filter_dat",
    srcs = ["filter_dat.py"],
    visibility = ["//visibility:public"],
)

exports_files(["icu_data_remove.txt"])
