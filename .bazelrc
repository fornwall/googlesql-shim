# Toolchain
# ---------
# GoogleSQL is developed against Clang, so build with Clang too. GCC 15 makes
# -Wchanges-meaning a hard error, which rejects
# `virtual const Type* Type() const` in public/property_graph.h.
#
# CC/CXX are deliberately NOT set here: pass them on the command line, e.g.
#   bazel build --repo_env=CC=/usr/bin/clang-18 --repo_env=CXX=/usr/bin/clang++-18 ...
# (the release workflow does exactly that with the runner's clang).
#
# Upstream registers its own hermetic LLVM toolchain, but only as a
# dev_dependency -- so it applies when GoogleSQL is the root module, not when
# it is a dependency as it is here. That is just as well: the bundled LLVM's
# ld.lld needs libxml2.so.2, which modern distros no longer ship.

# Language
# --------
build --cxxopt=-std=c++20 --host_cxxopt=-std=c++20

# A Clang defaulting to C23 rejects C sources that use `bool` as an identifier;
# `-std=gnu17` pins every C compilation to the older dialect (protobuf, zlib,
# and the other vendored C code).
build --conlyopt=-std=gnu17 --host_conlyopt=-std=gnu17

# Warnings, mirroring the `build:clang` config in GoogleSQL's own .bazelrc.
build --cxxopt=-Wno-deprecated-declarations
build --cxxopt=-Wno-inconsistent-missing-override
build --cxxopt=-Wno-range-loop-analysis
build --cxxopt=-Wno-char-subscripts
build --cxxopt=-Wno-enum-compare-switch
build --cxxopt=-Wno-defaulted-function-deleted
build --cxxopt=-Wno-unused-private-field
build --cxxopt=-Wno-unused-const-variable
build --cxxopt=-Wno-unused-function
build --cxxopt=-Wno-macro-redefined
build --cxxopt=-Wno-unused-command-line-argument
build --cxxopt=-Wno-module-import-in-extern-c

# Platform-specific sections below (build:linux / build:macos).
common --enable_platform_specific_config

# Linking (Linux only -- ld64 on macOS has neither flag spelling, and the
# problem is GNU-ld-specific)
# -------
# Bazel emits -lstdc++ inside a --push-state,-as-needed block. ICU places
# LDFLAGS before its object files, so -as-needed drops it and the C++ runtime
# symbols go unresolved. --no-as-needed, plus a spelling that is not
# deduplicated against Bazel's own entry, forces it to land last. Works on
# both glibc and musl (Alpine ships libstdc++.so.6 too).
build:linux --linkopt=-Wl,--no-as-needed --linkopt=-l:libstdc++.so.6
build:linux --host_linkopt=-Wl,--no-as-needed --host_linkopt=-l:libstdc++.so.6

# Visibility
# ----------
# //googlesql/local_service is package-private to //googlesql/..., so an
# external module cannot depend on it under normal visibility rules. The shim
# deliberately reaches past that boundary; it is the whole point of this repo.
build --check_visibility=false

# Loading
# -------
# grpc-java's java_grpc_library.bzl uses the ProtoInfo global, which newer
# protobuf rules no longer autoload. GoogleSQL's local_service BUILD declares
# Java targets alongside the C++ ones, so merely loading that package fails
# without this -- even though the shim only needs the cc_library and never
# links gRPC. Enabling autoload drops every native rule not listed, hence the
# full set rather than just ProtoInfo.
common --incompatible_autoload_externally=+ProtoInfo,+CcInfo,+JavaInfo,+JavaPluginInfo,+proto_library,+cc_library,+cc_binary,+cc_test,+cc_import,+cc_proto_library,+cc_shared_library,+java_library,+java_binary,+java_test,+java_import,+java_plugin,+java_proto_library,+java_lite_proto_library

# Sanitizers
# ----------
# For the C++-side safeguards on the callback-catalog path (must be built
# with Clang -- pass CC/CXX on the command line as above):
#   bazel test --config=asan  //shim:shim_callback_test
#   bazel test --config=tsan  //shim:shim_callback_test
#   bazel test --config=ubsan //shim:shim_callback_test
# Each config is its own Bazel configuration, so the first build recompiles
# the whole GoogleSQL dependency tree under that sanitizer (tens of minutes
# cold; cached afterwards). `--experimental_convenience_symlinks=ignore`
# keeps bazel-bin and friends pointing at the default build's artifacts -- a
# sanitizer build must never silently repoint them.
build:sanitizer-common --strip=never
build:sanitizer-common --copt=-g
build:sanitizer-common --copt=-O1
build:sanitizer-common --copt=-fno-omit-frame-pointer
build:sanitizer-common --experimental_convenience_symlinks=ignore

# `--platform_suffix` gives each sanitizer its own output tree: plain --copt
# changes do not change the output directory, so without it each config
# rebuilds *in place*, clobbering the default artifacts and forcing a full
# recompile on the way back (measured, in smallquery: the first sanitizer run
# rebuilt ~1.7k actions it did not need to).
build:asan --config=sanitizer-common
build:asan --platform_suffix=-asan
build:asan --copt=-fsanitize=address
build:asan --linkopt=-fsanitize=address

build:tsan --config=sanitizer-common
build:tsan --platform_suffix=-tsan
build:tsan --copt=-fsanitize=thread
build:tsan --linkopt=-fsanitize=thread

build:ubsan --config=sanitizer-common
build:ubsan --platform_suffix=-ubsan
build:ubsan --copt=-fsanitize=undefined
build:ubsan --copt=-fno-sanitize-recover=all
build:ubsan --linkopt=-fsanitize=undefined

# WebAssembly (experimental)
# --------------------------
# `--config=wasm` targets wasm32-unknown-emscripten via the emsdk Bazel
# toolchain declared in MODULE.bazel. Compilation-only so far: see the PR /
# branch notes for what builds and what is blocked.
build:wasm --platforms=@emsdk//:platform_wasm
